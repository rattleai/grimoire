{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rattleapp.de/schemas/apply-operations.schema.json",
  "title": "Rattle Apply-Config Operations",
  "description": "Idempotent ensure_* operations executed by rattle-apply-config / rattle-config-builder. Seven operation types, name-matched, get-or-create. See skills/rattle-apply-config/references/operations-contract.md for the canonical narrative.",
  "type": "object",
  "required": ["operations"],
  "properties": {
    "tenant": { "type": "string", "minLength": 1 },
    "recommendation_source": {
      "type": "string",
      "description": "Path or hash identifying where the recommendation came from."
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operation" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "operation": {
      "oneOf": [
        { "$ref": "#/$defs/ensure_product" },
        { "$ref": "#/$defs/ensure_area" },
        { "$ref": "#/$defs/ensure_group" },
        { "$ref": "#/$defs/ensure_option" },
        { "$ref": "#/$defs/ensure_area_config" },
        { "$ref": "#/$defs/ensure_constraint_pair" },
        { "$ref": "#/$defs/ensure_constraint_rule" }
      ]
    },
    "ensure_product": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": { "const": "ensure_product" },
        "name": { "type": "string", "minLength": 1 },
        "base_price": { "type": "number", "minimum": 0 },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ensure_area": {
      "type": "object",
      "required": ["type", "name", "parent_product"],
      "properties": {
        "type": { "const": "ensure_area" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "parent_product": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ensure_group": {
      "type": "object",
      "required": ["type", "name", "is_multi"],
      "properties": {
        "type": { "const": "ensure_group" },
        "name": { "type": "string", "minLength": 1 },
        "is_multi": { "type": "boolean" },
        "description": { "type": "string" },
        "link_to_areas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of every area across all products that this group should be linked to (POST /groups/{id}/areas one call per area)."
        }
      },
      "additionalProperties": false
    },
    "ensure_option": {
      "type": "object",
      "required": ["type", "name", "group", "price"],
      "properties": {
        "type": { "const": "ensure_option" },
        "name": { "type": "string", "minLength": 1 },
        "group": { "type": "string", "minLength": 1 },
        "price": { "type": "number", "minimum": 0 },
        "recommended": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ensure_area_config": {
      "type": "object",
      "required": ["type", "option", "area", "price"],
      "properties": {
        "type": { "const": "ensure_area_config" },
        "option": { "type": "string", "minLength": 1 },
        "area":   { "type": "string", "minLength": 1 },
        "price":  { "type": "number", "minimum": 0 },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ensure_constraint_pair": {
      "type": "object",
      "required": ["type", "product", "option_1", "option_2"],
      "properties": {
        "type": { "const": "ensure_constraint_pair" },
        "product":  { "type": "string", "minLength": 1 },
        "option_1": { "type": "string", "minLength": 1 },
        "option_2": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ensure_constraint_rule": {
      "type": "object",
      "required": ["type", "product", "description", "rule_json"],
      "properties": {
        "type": { "const": "ensure_constraint_rule" },
        "product": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "rule_json": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "if": {
                "type": "object",
                "properties": {
                  "option_selected": { "type": "string" }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "forbid_options": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
